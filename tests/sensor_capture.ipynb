   "source": [
    "import serial\n",
    "\n",
    "ser = serial.Serial('COM6', 115200, timeout=1)\n",
    "\n",
    "while True:\n",
    "    line = ser.readline().decode('utf-8').strip()\n",
    "    \n",
    "    if line:\n",
    "        print(line)"
